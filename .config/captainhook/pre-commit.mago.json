{
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "{$ENV|value-of:VENDOR_BIN_DIR|default:vendor/bin/}mago --config={$ENV|value-of:XDG_CONFIG_HOME|default:mago.dist.toml} lint --baseline lint-baseline.toml {$STAGED_FILES|of-type:php|separated-by: }",
                "config": {
                    "label": "Lint Files (with Mago)"
                }
            }
        ]
    }
}
