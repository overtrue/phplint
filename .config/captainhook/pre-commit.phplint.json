{
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": [
                    "bin/phplint",
                    "--configuration={$ENV|value-of:\\Bartlett\\CaptainHookBinPlugin\\BinPlugin.config-file|cache:false}",
                    "--no-progress",
                    "{$ENV|value-of:\\Bartlett\\CaptainHookBinPlugin\\BinPlugin.colors-flag|cache:false}",
                    "{$STAGED_FILES|of-type:php|separated-by: }"
                ],
                "config": {
                    "label": "Lint Files (with PHPLint)"
                },
                "options": {
                    "colors": "ansi",
                    "config-file": "./.phplint.yml.dist"
                }
            }
        ]
    }
}
